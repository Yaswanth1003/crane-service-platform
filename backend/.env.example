# Server Configuration
PORT=5000

# MongoDB Atlas Connection String
# Get this from MongoDB Atlas: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?appName=Cluster0
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/crane-service?appName=Cluster0

# JWT Secret for token generation
JWT_SECRET=your_secure_jwt_secret_here

# SMTP Configuration (recommended)
# For Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_SECURE=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=duttacraneservices@gmail.com
SMTP_PASS=your_smtp_password_or_app_password
SMTP_FROM_NAME=DATTA Crane Services
SMTP_FROM_EMAIL=your_smtp_username

# Backward-compatible email variables (optional if SMTP_USER/SMTP_PASS are set)
EMAIL_USER=your_smtp_username
EMAIL_PASS=your_smtp_password_or_app_password

# Recipient for admin booking notifications
ADMIN_NOTIFICATION_EMAIL=duttacraneservices@gmail.com

# Frontend URL for links in emails (optional)
CLIENT_URL=http://localhost:5173

# Admin setup bootstrap key
ADMIN_SETUP_KEY=replace_with_secure_key
