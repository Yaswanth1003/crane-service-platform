# Server Configuration
PORT=5000

# MongoDB Atlas Connection String
# Get this from MongoDB Atlas: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?appName=Cluster0
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/crane-service?appName=Cluster0

# JWT Secret for token generation
JWT_SECRET=your_secure_jwt_secret_here

# Email Configuration (for contact form & notifications)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_from_gmail

# SMTP Settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SERVICE=
SMTP_FROM=your_email@gmail.com
ADMIN_NOTIFICATION_EMAIL=admin@example.com

# Optional SMTP reliability settings
SMTP_TIMEOUT_MS=10000
EMAIL_RETRY_COUNT=2
EMAIL_RETRY_DELAY_MS=1000
MAIL_DEBUG_TO=

# Optional fallback provider (secondary SMTP)
SMTP_FALLBACK_HOST=
SMTP_FALLBACK_PORT=587
SMTP_FALLBACK_SERVICE=
SMTP_FALLBACK_USER=
SMTP_FALLBACK_PASS=
